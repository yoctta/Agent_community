# Required: API key for the LLM provider used by OpenClaw agents.
LLM_API_KEY=sk-your-key-here

# LLM provider and model (used by OpenClaw gateways).
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-sonnet-4-20250514    # model for agent reasoning

# Optional: Moltbook API key for live external interaction.
MOLTBOOK_API_KEY=

# Experiment settings (override via CLI flags).
DAYS_PER_RUN=30
SEED=42
