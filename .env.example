# ============================================================
# ACES Environment Configuration
# ============================================================
# Copy this file:  cp .env.example .env
# Then edit .env with your actual keys.
#
# There are three runtime modes. You only need to configure
# the one you plan to use.
#
# ============================================================
# MODE 1: Mock agents (no LLM, no API key needed)
# ============================================================
# Run with:  python run_experiment.py single --backend mock
# Or:        docker compose run simulator single --backend mock
# No configuration needed — agents use deterministic rules.

# ============================================================
# MODE 2: Direct LLM API (no OpenClaw, lightweight)
# ============================================================
# Run with:  python run_experiment.py single --backend anthropic
# Or:        python run_experiment.py single --backend openai
#
# The simulator calls the LLM API directly for each agent.
# Set ONE of the following:

# For Anthropic (Claude):
# LLM_API_KEY=sk-ant-api03-your-anthropic-key
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514

# For OpenAI:
# LLM_API_KEY=sk-your-openai-key
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ============================================================
# MODE 3: OpenClaw agents (full autonomous agents via Docker)
# ============================================================
# Run with:  docker compose up
#
# Each of the 12 agents runs in its own OpenClaw gateway container.
# OpenClaw reads LLM_API_KEY from the environment and uses it to
# call the LLM provider configured in each agent's config.yaml.
#
# Step 1: Set your API key here.
# Step 2: Choose provider/model and regenerate agent configs:
#         python docker/generate_agent_configs.py --provider anthropic --model claude-sonnet-4-20250514
# Step 3: docker compose up

LLM_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# ============================================================
# Optional: Moltbook (external agent social network)
# ============================================================
# Only needed for live Moltbook interaction (not simulated mode).
# Get a key at https://moltbook.com after registering your agent.

MOLTBOOK_API_KEY=
